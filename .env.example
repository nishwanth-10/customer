# ══════════════════════════════════════════════════════════════════
# Customer Ledger Pro — Environment Variables Template
# ══════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values
# NEVER commit .env to git!
# ══════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
APP_NAME=Customer Ledger Pro
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production   # development | staging | production

# ── Security (REQUIRED) ───────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
OTP_EXPIRE_MINUTES=5

# ── Database (REQUIRED) ───────────────────────────────────────────
# Local development:
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/customer_ledger
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/customer_ledger
POSTGRES_PASSWORD=your-strong-password

# Render.com managed DB (replace with your Render DB URL):
# DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Firebase (REQUIRED for push + Google auth) ────────────────────
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── Twilio SMS (for OTP + Payment Reminders) ─────────────────────
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# ── Twilio WhatsApp ───────────────────────────────────────────────
# Sandbox: whatsapp:+14155238886
# Production: whatsapp:+your-approved-number
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Google OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── CORS ──────────────────────────────────────────────────────────
# For production, restrict to your domain:
# BACKEND_CORS_ORIGINS=["https://yourdomain.com"]
BACKEND_CORS_ORIGINS=["*"]

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10
